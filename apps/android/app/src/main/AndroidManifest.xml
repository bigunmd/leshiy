<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- registerDefaultNetworkCallback, so a Wi-Fi<->cellular switch re-dials at once instead of
         waiting out the mux idle timeout. Both this and INTERNET were previously arriving only
         via a dependency's manifest merge — declared here because we depend on them directly. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.CAMERA" />

    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <!-- Android 11+ package visibility: needed to list launchable apps for split tunnel. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="Leshiy"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.QrScanActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Wakes the CPU so the tunnel's keepalive can fire while the device sleeps (ADR-0031).
             Not exported: only our own AlarmManager PendingIntent triggers it. No
             SCHEDULE_EXACT_ALARM permission — setAndAllowWhileIdle is inexact and needs none, and
             a keepalive doesn't care about a few minutes of jitter. -->
        <receiver
            android:name=".KeepalivePingReceiver"
            android:exported="false" />

        <service
            android:name=".LeshiyVpnService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>
    </application>
</manifest>
