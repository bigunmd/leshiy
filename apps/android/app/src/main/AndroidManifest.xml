<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- registerDefaultNetworkCallback, so a Wi-Fi<->cellular switch re-dials at once instead of
         waiting out the mux idle timeout. Both this and INTERNET were previously arriving only
         via a dependency's manifest merge — declared here because we depend on them directly. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- In-app updater: hand the downloaded APK to the platform installer. Android routes the
         user through the one-time "allow installs from this source" grant on first use. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Reconnect the active profile after a reboot (BootReceiver), gated on a user toggle. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- One-tap "allow background activity" dialog so the sleep-keepalive alarm (ADR-0031) can
         wake the CPU under Doze. Distributed via GitHub APK, so Play's restriction on this
         permission doesn't apply. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <!-- Android 11+ package visibility: needed to list launchable apps for split tunnel. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="Leshiy"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Launcher long-press shortcuts (Connect / Disconnect). -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <activity
            android:name=".ui.QrScanActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Wakes the CPU so the tunnel's keepalive can fire while the device sleeps (ADR-0031).
             Not exported: only our own AlarmManager PendingIntent triggers it. No
             SCHEDULE_EXACT_ALARM permission — setAndAllowWhileIdle is inexact and needs none, and
             a keepalive doesn't care about a few minutes of jitter. -->
        <receiver
            android:name=".KeepalivePingReceiver"
            android:exported="false" />

        <!-- Reconnect the active profile after a reboot or an app self-update. exported=true is
             required to receive the system BOOT_COMPLETED broadcast; MY_PACKAGE_REPLACED is
             delivered only to our own package. The gate is BootReceiver + shouldAutoStart. -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <service
            android:name=".LeshiyVpnService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- Quick Settings toggle. exported + BIND_QUICK_SETTINGS_TILE is the platform
             contract for tiles: only SystemUI holds that permission, so nothing else can bind. -->
        <service
            android:name=".LeshiyTileService"
            android:exported="true"
            android:icon="@drawable/ic_qs_leshiy"
            android:label="Leshiy"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Home-screen toggle widget. exported so the launcher/host can bind it; the toggle
             broadcast is our own package action. -->
        <receiver
            android:name=".LeshiyWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="dev.leshiy.WIDGET_TOGGLE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/leshiy_widget_info" />
        </receiver>

        <!-- Exposes the downloaded update APK (cacheDir/updates) to the package installer. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="dev.leshiy.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/update_paths" />
        </provider>
    </application>
</manifest>
