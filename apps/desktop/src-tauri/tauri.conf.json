{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Leshiy",
  "version": "1.3.0",
  "identifier": "app.leshiy.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Leshiy",
        "width": 420,
        "height": 680,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/leshiy-helper"],
    "category": "Utility",
    "shortDescription": "Censorship-circumvention client",
    "longDescription": "Leshiy is a fast, secure censorship-circumvention client. Import a config, connect with one tap, and route your traffic through a local SOCKS5 proxy over the Leshiy protocol (REALITY/QUIC with auto-fallback).",
    "copyright": "© 2026 Mikhail Bigun",
    "publisher": "Leshiy",
    "licenseFile": "../../../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": { "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"] }
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  }
}
