#!/bin/sh
# leshiyctl — mode-aware day-2 dispatcher. Reads /etc/leshiy/install.json (written by the
# installer) to route verbs to native `leshiy` subcommands or a plain docker container. POSIX sh.
set -eu

CFGDIR="/etc/leshiy"
CONFIG="$CFGDIR/server.toml"
STATE="$CFGDIR/install.json"
DOCKER_NAME="leshiy"

mode() {  # "docker" if the install used a container, else "native"
  if [ -f "$STATE" ] && grep -q '"mode" *: *"docker"' "$STATE" 2>/dev/null; then
    echo docker
  else
    echo native
  fi
}

docker_image() {  # the image ref the installer recorded in install.json
  grep -o '"image":"[^"]*"' "$STATE" 2>/dev/null | cut -d'"' -f4
}

run_server_container() {  # (re)create the leshiy container from the recorded image
  img="$(docker_image)"
  [ -n "$img" ] || { echo "no image recorded in $STATE" >&2; exit 1; }
  docker rm -f "$DOCKER_NAME" >/dev/null 2>&1 || true
  docker run -d --name "$DOCKER_NAME" --restart unless-stopped \
    --user 0:0 --network host \
    -v "$CFGDIR":/etc/leshiy \
    "$img" server --config /etc/leshiy/server.toml
}

resolve_latest_tag() {  # $1 = owner/repo on GitHub → its latest release tag (e.g. v1.2.3)
  curl -fsSL "https://api.github.com/repos/$1/releases/latest" 2>/dev/null \
    | grep -m1 '"tag_name"' | cut -d'"' -f4
}

write_image() {  # $1 = image ref → record it as the docker install image
  printf '{"mode":"docker","image":"%s"}\n' "$1" > "$STATE"
}

usage() {
  echo "usage: leshiyctl {status|upgrade [VERSION]|uninstall [--purge]|user ...}" >&2
  exit 2
}

[ $# -ge 1 ] || usage
verb="$1"; shift

case "$verb" in
  status)
    if [ "$(mode)" = docker ]; then
      docker ps -a --filter "name=^${DOCKER_NAME}$" \
        --format 'container: {{.Names}}  status: {{.Status}}  image: {{.Image}}'
      docker logs --tail 5 "$DOCKER_NAME" 2>&1 || true
    else
      leshiy status --config "$CONFIG"
    fi
    ;;
  upgrade)
    # Optional positional VERSION (e.g. v1.2.3) pins a specific release; omit for latest.
    ver="${1:-}"
    if [ "$(mode)" = docker ]; then
      img="$(docker_image)"
      [ -n "$img" ] || { echo "no image recorded in $STATE" >&2; exit 1; }
      base="${img%:*}"      # strip the :tag → registry/owner/repo
      ghrepo="${base#*/}"   # strip the registry host → owner/repo (for the GitHub API)
      tag="$ver"
      if [ -z "$tag" ]; then
        tag="$(resolve_latest_tag "$ghrepo")"
        [ -n "$tag" ] || {
          echo "could not resolve latest release for $ghrepo (try: leshiyctl upgrade vX.Y.Z)" >&2
          exit 1
        }
      fi
      newimg="$base:$tag"
      docker pull "$newimg"
      write_image "$newimg"  # record the now-running version so `status` stays accurate
      run_server_container
    elif [ -n "$ver" ]; then
      leshiy upgrade --version "$ver"
    else
      leshiy upgrade
    fi
    ;;
  uninstall)
    if [ "$(mode)" = docker ]; then
      docker rm -f "$DOCKER_NAME" >/dev/null 2>&1 || true
      case "${1:-}" in --purge) rm -rf "$CFGDIR" ;; esac
    else
      leshiy uninstall --config "$CONFIG" "$@"
    fi
    ;;
  user)
    if [ "$(mode)" = docker ]; then
      # Run the user command inside the container, where the control socket + DB live.
      docker exec "$DOCKER_NAME" /usr/local/bin/leshiy user "$@" --config /etc/leshiy/server.toml
    else
      leshiy user "$@" --config "$CONFIG"
    fi
    ;;
  *) usage ;;
esac
